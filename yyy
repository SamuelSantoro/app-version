-- LocalScript en StarterPlayerScripts
local COLOR  = Color3.fromRGB(255, 255, 255)
local TAMANO = 32
local TOTAL  = 4

if not game:IsLoaded() then game.Loaded:Wait() end
local player      = game.Players.LocalPlayer
local itemsFolder = workspace:WaitForChild("Items")
local collected   = 0

local gui = Instance.new("ScreenGui")
gui.Name         = "CollectGui"
gui.ResetOnSpawn = false
gui.Parent       = player:WaitForChild("PlayerGui")

local label = Instance.new("TextLabel")
label.AnchorPoint            = Vector2.new(1, 0)
label.Position               = UDim2.new(1, -20, 0, 20)
label.Size                   = UDim2.new(0, 200, 0, 50)
label.BackgroundTransparency = 1
label.TextColor3             = COLOR
label.TextSize               = TAMANO
label.Font                   = Enum.Font.GothamBold
label.TextXAlignment         = Enum.TextXAlignment.Right
label.Text                   = "0/" .. TOTAL
label.Parent                 = gui

local function conectarItem(item)
	local clicked = false

	local function setupPart(part)
		if part:FindFirstChild("ClickDetector") then return end
		local cd = Instance.new("ClickDetector")
		cd.MaxActivationDistance = 100
		cd.Parent = part
		cd.MouseClick:Connect(function()
			if clicked then return end
			clicked = true
			item:Destroy()
			collected += 1
			label.Text = collected == TOTAL
				and "Ganaste!"
				or collected .. "/" .. TOTAL
		end)
	end

	if item:IsA("BasePart") then
		setupPart(item)
	else
		-- todas las parts que ya existen en el model
		for _, desc in pairs(item:GetDescendants()) do
			if desc:IsA("BasePart") then
				setupPart(desc)
			end
		end
		-- parts que lleguen después por streaming
		item.DescendantAdded:Connect(function(desc)
			if clicked then return end
			if desc:IsA("BasePart") then
				setupPart(desc)
			end
		end)
	end
end

for _, item in pairs(itemsFolder:GetChildren()) do
	conectarItem(item)
end

itemsFolder.ChildAdded:Connect(conectarItem)
