-- LocalScript en StarterPlayerScripts
local COLOR  = Color3.fromRGB(255, 255, 255)  -- COLOR DEL TEXTO
local TAMANO = 32                              -- TAMANO DEL TEXTO
local TOTAL  = 4                               -- CUANTOS ITEMS HAY
-- (no tocar de aqui para abajo)
if not game:IsLoaded() then game.Loaded:Wait() end
local player      = game.Players.LocalPlayer
local itemsFolder = workspace:WaitForChild("Items")
local collected   = 0
local gui = Instance.new("ScreenGui")
gui.Name         = "CollectGui"
gui.ResetOnSpawn = false
gui.Parent       = player:WaitForChild("PlayerGui")
local label = Instance.new("TextLabel")
label.AnchorPoint            = Vector2.new(1, 0)
label.Position               = UDim2.new(1, -20, 0, 20)
label.Size                   = UDim2.new(0, 200, 0, 50)
label.BackgroundTransparency = 1
label.TextColor3             = COLOR
label.TextSize               = TAMANO
label.Font                   = Enum.Font.GothamBold
label.TextXAlignment         = Enum.TextXAlignment.Right
label.Text                   = "0/" .. TOTAL
label.Parent                 = gui

local function conectarItem(item)
    local function setup(target)
        if target:FindFirstChild("ClickDetector") then return end
        local cd = Instance.new("ClickDetector")
        cd.MaxActivationDistance = 100
        cd.Parent = target
        cd.MouseClick:Connect(function()
            item:Destroy()
            collected += 1
            label.Text = collected == TOTAL
                and "Ganaste!"
                or collected .. "/" .. TOTAL
        end)
    end

    if item:IsA("BasePart") then
        setup(item)
    else
        local target = item:FindFirstChildWhichIsA("BasePart", true)
        if target then
            setup(target)
        else
            local conn
            conn = item.DescendantAdded:Connect(function(desc)
                if desc:IsA("BasePart") then
                    conn:Disconnect()
                    setup(desc)
                end
            end)
        end
    end
end

-- items ya cargados al entrar
for _, item in pairs(itemsFolder:GetChildren()) do
    conectarItem(item)
end

-- items que lleguen despues por streaming
itemsFolder.ChildAdded:Connect(conectarItem)
